# docker-compose environment — copy to .env and fill in secrets
# (.env is gitignored; non-secret local overrides go in application-local.yml)
#
# direnv loads this file automatically so these vars are also available to
# ./gradlew bootRun — Spring Boot resolves ${VAR} placeholders from the env.

# ── Resend ──────────────────
──────────────────────────────────────────────────
# Used by the Spring Boot app (transactional emails) AND by Zitadel SMTP
# (invitation emails) — wired in docker-compose.yml, no duplication needed.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_ADDRESS=noreply@yourdomain.com
RESEND_FROM_NAME="Kotlin SaaS Template"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use sk_test_… for local/staging, sk_live_… for production.
# STRIPE_WEBHOOK_SECRET — run `stripe listen --forward-to localhost:8080/webhooks/stripe` and copy the printed whsec_…
# STRIPE_PRICE_PRO — create once with `stripe prices create` (test mode). See CLAUDE.md "Testing plans locally".
STRIPE_API_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxx

# ── Social login (Zitadel IDPs) ───────────────────────────────────────────────
# All providers are optional. Leave vars empty (or unset) to skip a provider —
# the stack boots cleanly without any social credentials.
#
# Callback URL to register in each provider's developer console:
#   http://localhost:8089/idps/callback
# NOTE: this is Zitadel core (port 8089), not the login UI (port 3000).
# LOGINV2_BASEURI is set to localhost:8089 so that both the OAuth redirect_uri
# Zitadel sends to the provider AND the redirect_uri it uses in the token
# exchange are consistent.  Mismatching them causes invalid_grant errors.
#
# Google — https://console.developers.google.com/
#   OAuth 2.0 client (Web application), add http://localhost:8089/idps/callback
#   as an Authorized redirect URI.
ZITADEL_DEV_GOOGLE_CLIENT_ID=
ZITADEL_DEV_GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers (OAuth Apps)
#   Homepage URL: http://localhost:8089
#   Authorization callback URL: http://localhost:8089/idps/callback
ZITADEL_DEV_GITHUB_CLIENT_ID=
ZITADEL_DEV_GITHUB_CLIENT_SECRET=

# Microsoft (Entra ID / Azure AD) — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
#   Register a Web app, add http://localhost:8089/idps/callback as a redirect URI.
#   TENANT: your Entra tenant ID (UUID), or "common" for multi-tenant.
ZITADEL_DEV_MICROSOFT_CLIENT_ID=
ZITADEL_DEV_MICROSOFT_CLIENT_SECRET=
ZITADEL_DEV_MICROSOFT_TENANT=common

# Apple — https://developer.apple.com/account/resources/identifiers/list/serviceId
#   Create a Services ID, enable "Sign In with Apple", add
#   http://localhost:8089/idps/callback as a Return URL.
#   PRIVATE_KEY: contents of the .p8 file (PEM, including -----BEGIN/END PRIVATE KEY----- lines).
ZITADEL_DEV_APPLE_CLIENT_ID=
ZITADEL_DEV_APPLE_TEAM_ID=
ZITADEL_DEV_APPLE_KEY_ID=
ZITADEL_DEV_APPLE_PRIVATE_KEY=
