# docker-compose environment — copy to .env and fill in secrets
# (.env is gitignored; non-secret local overrides go in application-local.yml)
#
# direnv loads this file automatically so these vars are also available to
# ./gradlew bootRun — Spring Boot resolves ${VAR} placeholders from the env.

# ── Resend ────────────────────────────────────────────────────────────────────
# Used by the Spring Boot app (transactional emails) AND by Zitadel SMTP below.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_ADDRESS=noreply@yourdomain.com
RESEND_FROM_NAME=Kotlin SaaS Template

# ── Zitadel SMTP (invitation emails) ─────────────────────────────────────────
# Zitadel sends invitation emails through its own SMTP provider, separate from
# the app's Resend client. Applied on first-run only — run dev-reset.sh after
# setting these for the first time.
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_HOST=smtp.resend.com:587
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_USER=resend
# Password is RESEND_API_KEY — wired in docker-compose.yml, no need to repeat it here.
# RESEND_FROM_NAME and RESEND_FROM_ADDRESS are also used for Zitadel SMTP — wired in docker-compose.yml.
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_TLS=true
