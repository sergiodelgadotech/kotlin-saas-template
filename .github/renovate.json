{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "timezone": "Europe/Madrid",
  "schedule": ["before 6am"],
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "automerge": false,
  "packageRules": [
    {
      "description": "kotlin-saas-starter always gets a dedicated PR; lives on GitHub Packages not Maven Central",
      "matchPackageNames": ["tech.sergiodelgado:kotlin-saas-starter"],
      "registryUrls": ["https://maven.pkg.github.com/sergiodelgadotech/kotlin-saas-starter"],
      "groupName": null,
      "commitMessageAction": "bump",
      "commitMessageTopic": "kotlin-saas-starter",
      "commitMessageExtra": "to {{newVersion}}"
    },
    {
      "description": "Group non-major Gradle dependency updates",
      "matchManagers": ["gradle", "gradle-wrapper", "gradle-version-catalog"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "gradle dependencies (non-major)",
      "matchPackageNames": [
        "!tech.sergiodelgado:kotlin-saas-starter"
      ]
    },
    {
      "description": "Group non-major GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions (non-major)"
    },
    {
      "description": "Group non-major Docker image updates",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "docker images (non-major)",
      "matchPackageNames": [
        "!ghcr.io/zitadel/zitadel"
      ]
    },
    {
      "description": "Group non-major Terraform provider updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "terraform providers (non-major)"
    },
    {
      "description": "Group Spring ecosystem major updates into one PR",
      "matchPackageNames": [
        "/^org\\.springframework/",
        "/^org\\.jobrunr:jobrunr-spring-boot-.*-starter$/",
        "/^org\\.jetbrains\\.kotlin/"
      ],
      "matchUpdateTypes": ["major"],
      "groupName": "Spring ecosystem (major)"
    },
    {
      "description": "Security fixes use fix(deps): so they appear in the changelog",
      "matchCategories": ["security"],
      "semanticCommitType": "fix",
      "groupName": null,
      "automerge": false
    },
    {
      "description": "Zitadel is pinned to :latest — disable until properly versioned (see issue #28)",
      "matchPackageNames": ["ghcr.io/zitadel/zitadel"],
      "enabled": false
    }
  ]
}
