# Local development overrides — never commit secrets here
# Copy this to application-local.yml and fill in your values
spring:
  config:
    import:
      # Auto-generated by zitadel-init on first `docker compose up -d`.
      # Contains ZITADEL_CLIENT_ID — no manual copy needed.
      - optional:file:../docker/zitadel-init/.local-client.properties
  datasource:
    url: jdbc:postgresql://localhost:5432/saastemplate
    username: saastemplate
    password: saastemplate
  thymeleaf:
    cache: false
  flyway:
    locations:
      - classpath:db/migration
      - classpath:db/migration/saasstarter
      - classpath:db/migration/local

saasstarter:
  security:
    jwks-url: http://localhost:8089/oauth/v2/keys
    issuer: http://localhost:8089
  email:
    api-key: re_REPLACE_ME
    from-address: no-reply@example.com

# These match the ${ENV_VAR} placeholders in application.yml.
# Any non-empty string is enough to let the app start; real values only needed when
# hitting the billing or email flows.
# Zitadel — points at the docker-compose instance (:8089).
# ZITADEL_CLIENT_ID is auto-imported from docker/zitadel-init/.local-client.properties
# (written by zitadel-init on first `docker compose up -d`).
AUTH_ISSUER: http://localhost:8089
AUTH_JWKS_URL: http://localhost:8089/oauth/v2/keys
ZITADEL_CLIENT_SECRET:                # leave blank — PKCE, no secret needed
STRIPE_API_KEY: sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET: whsec_REPLACE_ME
STRIPE_PRICE_STARTER: price_REPLACE_ME
STRIPE_PRICE_PRO: price_REPLACE_ME
RESEND_API_KEY: re_REPLACE_ME

saastemplate:
  zitadel:
    management:
      base-url: http://localhost:8089
      # Auto-generated by zitadel-init on first `docker compose up -d`.
      # Pass via environment variable — do NOT paste the token here.
      # Usage: ZITADEL_MGMT_PAT=$(cat docker/zitadel-init/management-api.pat) ./gradlew :app:bootRun --args='--spring.profiles.active=local'
      pat: ${ZITADEL_MGMT_PAT:}
      organization-id: "<your-zitadel-org-id>"

app:
  base-url: http://localhost:8080

logging:
  level:
    tech.sergiodelgado.saastemplate: DEBUG
    org.springframework.security: DEBUG
